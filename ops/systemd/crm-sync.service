[Unit]
Description=crm.eg.je sync + scheduled workers
After=network.target postgresql.service redis-server.service crm-api.service

[Service]
Type=simple
User=crm
WorkingDirectory=/opt/crm.eg.je/apps/api
EnvironmentFile=/etc/crm/secrets.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/node dist/workers.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
