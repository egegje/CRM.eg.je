generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  manager
}

enum FolderKind {
  inbox
  sent
  drafts
  trash
  custom
}

enum SendStatus {
  pending
  sent
  failed
  cancelled
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime        @default(now())
  lastLoginAt  DateTime?
  folders      Folder[]
  scheduled    ScheduledSend[]
}

model Mailbox {
  id                   String          @id @default(cuid())
  email                String          @unique
  displayName          String
  encryptedAppPassword Bytes
  imapHost             String          @default("imap.mail.ru")
  imapPort             Int             @default(993)
  smtpHost             String          @default("smtp.mail.ru")
  smtpPort             Int             @default(465)
  enabled              Boolean         @default(true)
  signature            String?
  createdAt            DateTime        @default(now())
  folders              Folder[]
  messages             Message[]
  scheduled            ScheduledSend[]
  syncState            SyncState?
  users                UserMailbox[]
}

model UserMailbox {
  userId    String
  mailboxId String
  mailbox   Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, mailboxId])
  @@index([mailboxId])
}

model SyncState {
  mailboxId String   @id
  mailbox   Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  lastUid   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Folder {
  id        String     @id @default(cuid())
  mailbox   Mailbox?   @relation(fields: [mailboxId], references: [id])
  mailboxId String?
  owner     User?      @relation(fields: [ownerId], references: [id])
  ownerId   String?
  name      String
  kind      FolderKind
  parentId  String?
  messages  Message[]

  @@index([mailboxId, kind])
}

model Message {
  id          String       @id @default(cuid())
  mailbox     Mailbox      @relation(fields: [mailboxId], references: [id])
  mailboxId   String
  folder      Folder       @relation(fields: [folderId], references: [id])
  folderId    String
  imapUid     Int?
  messageId   String?      @unique
  fromAddr    String
  toAddrs     String[]
  ccAddrs     String[]
  subject     String
  bodyText    String?
  bodyHtml    String?
  isRead      Boolean      @default(false)
  isStarred   Boolean      @default(false)
  isDraft     Boolean      @default(false)
  receivedAt  DateTime?
  sentAt      DateTime?
  deletedAt   DateTime?
  aiSummary   String?
  aiActions   String[]
  aiPriority  String?
  attachments Attachment[]

  @@index([mailboxId, folderId, receivedAt])
  @@index([deletedAt])
}

model Attachment {
  id          String  @id @default(cuid())
  message     Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId   String
  filename    String
  mime        String
  size        Int
  storagePath String
}

model Rule {
  id        String   @id @default(cuid())
  triggerType String  // "from" | "to" | "subject"
  contains  String
  folderId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Contact {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  useCount    Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Snooze {
  id          String   @id @default(cuid())
  messageId   String   @unique
  snoozeUntil DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([snoozeUntil])
}

model SmartFolder {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  query     Json
  createdAt DateTime @default(now())
}

model TgNotify {
  id          String   @id @default(cuid())
  messageId   String
  tgMessageId Int
  createdAt   DateTime @default(now())

  @@index([tgMessageId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model ScheduledSend {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  mailbox   Mailbox    @relation(fields: [mailboxId], references: [id])
  mailboxId String
  payload   Json
  sendAt    DateTime
  status    SendStatus @default(pending)
  jobId     String?
  createdAt DateTime   @default(now())
}
