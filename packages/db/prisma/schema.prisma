generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  manager
}

enum FolderKind {
  inbox
  sent
  drafts
  trash
  custom
}

enum SendStatus {
  pending
  sent
  failed
  cancelled
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime        @default(now())
  lastLoginAt  DateTime?
  signature    String?
  folders      Folder[]
  scheduled    ScheduledSend[]
}

model Mailbox {
  id                   String          @id @default(cuid())
  email                String          @unique
  displayName          String
  encryptedAppPassword Bytes
  imapHost             String          @default("imap.mail.ru")
  imapPort             Int             @default(993)
  smtpHost             String          @default("smtp.mail.ru")
  smtpPort             Int             @default(465)
  enabled              Boolean         @default(true)
  signature            String?
  createdAt            DateTime        @default(now())
  folders              Folder[]
  messages             Message[]
  scheduled            ScheduledSend[]
  syncState            SyncState?
  users                UserMailbox[]
}

model UserMailbox {
  userId    String
  mailboxId String
  mailbox   Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, mailboxId])
  @@index([mailboxId])
}

model SyncState {
  mailboxId   String   @id
  mailbox     Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  lastUid     Int      @default(0)
  sentLastUid Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Folder {
  id        String     @id @default(cuid())
  mailbox   Mailbox?   @relation(fields: [mailboxId], references: [id])
  mailboxId String?
  owner     User?      @relation(fields: [ownerId], references: [id])
  ownerId   String?
  name      String
  kind      FolderKind
  parentId  String?
  messages  Message[]

  @@index([mailboxId, kind])
}

model Message {
  id          String       @id @default(cuid())
  mailbox     Mailbox      @relation(fields: [mailboxId], references: [id])
  mailboxId   String
  folder      Folder       @relation(fields: [folderId], references: [id])
  folderId    String
  imapUid     Int?
  messageId   String?      @unique
  fromAddr    String
  fromName    String?
  toAddrs     String[]
  ccAddrs     String[]
  subject     String
  bodyText    String?
  bodyHtml    String?
  isRead      Boolean      @default(false)
  isStarred   Boolean      @default(false)
  isDraft     Boolean      @default(false)
  receivedAt  DateTime?
  sentAt      DateTime?
  deletedAt   DateTime?
  aiSummary   String?
  aiActions   String[]
  aiPriority  String?
  senderUserId String?
  personaId   String?
  attachments Attachment[]

  @@index([mailboxId, folderId, receivedAt])
  @@index([deletedAt])
}

model Attachment {
  id             String    @id @default(cuid())
  message        Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId      String
  filename       String
  mime           String
  size           Int
  storagePath    String?
  sha256         String?
  cachedAt       DateTime?
  lastAccessedAt DateTime?
  imapUid        Int?
  imapPart       String?

  @@index([sha256])
  @@index([lastAccessedAt])
}

model Rule {
  id        String   @id @default(cuid())
  triggerType String  // "from" | "to" | "subject"
  contains  String
  folderId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Contact {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  useCount    Int      @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Template {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  body      String
  createdAt DateTime @default(now())

  @@index([ownerId])
}

model Snooze {
  id          String   @id @default(cuid())
  messageId   String   @unique
  snoozeUntil DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([snoozeUntil])
}

model SmartFolder {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  query     Json
  createdAt DateTime @default(now())
}

model TgNotify {
  id          String   @id @default(cuid())
  messageId   String
  tgMessageId Int
  createdAt   DateTime @default(now())

  @@index([tgMessageId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum TaskStatus {
  open
  in_progress
  awaiting_review
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

model Project {
  id         String   @id @default(cuid())
  name       String
  source     String   @default("manual")
  externalId String?
  notes      String?
  createdAt  DateTime @default(now())
  tasks      Task[]
}

model Task {
  id                   String       @id @default(cuid())
  title                String
  description          String?
  assigneeId           String?
  creatorId            String
  projectId            String?
  dueDate              DateTime?
  priority             TaskPriority @default(normal)
  status               TaskStatus   @default(open)
  category             String?
  sourceEmailMessageId String?
  sourceTgChatId       String?
  sourceTgMessageId    Int?
  createdAt            DateTime     @default(now())
  completedAt          DateTime?
  reviewRequestedAt    DateTime?
  pyrusId              Int?         @unique
  project              Project?     @relation(fields: [projectId], references: [id])
  comments             TaskComment[]
  tagAssignments       TaskTagAssignment[]
  attachments          TaskAttachment[]
  coAssignees          TaskCoAssignee[]

  @@index([assigneeId, status])
  @@index([dueDate, status])
  @@index([projectId])
}

model TaskCoAssignee {
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Persona {
  id        String   @id @default(cuid())
  name      String
  signature String
  createdAt DateTime @default(now())
}

model SberToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String?
  updatedAt    DateTime @default(now()) @updatedAt
}

model Company {
  id          String              @id @default(cuid())
  name        String
  inn         String?
  sberCustId  String?
  notes       String?
  createdAt   DateTime            @default(now())
  accounts    BankAccount[]
  userAccess  UserCompanyAccess[]
}

model UserCompanyAccess {
  userId    String
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, companyId])
  @@index([companyId])
}

model BankTransaction {
  id               String   @id @default(cuid())
  accountNumber    String
  operationDate    DateTime
  documentDate     DateTime?
  amount           Decimal  @db.Decimal(18, 2)
  direction        String   // DEBIT | CREDIT
  counterpartyName String?
  counterpartyInn  String?
  counterpartyAccount String?
  counterpartyBankBic String?
  paymentPurpose   String?
  paymentNumber    String?
  sberUuid         String?  @unique
  createdAt        DateTime @default(now())

  @@index([accountNumber, operationDate])
  @@index([operationDate])
}

model BankSyncState {
  accountNumber String   @id
  lastSyncDate  String   // YYYY-MM-DD
  updatedAt     DateTime @default(now()) @updatedAt
}

model BankAccount {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bank          String
  accountNumber String
  currency      String   @default("RUB")
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  notes         String?
  updatedAt     DateTime @default(now()) @updatedAt
  createdAt     DateTime @default(now())

  @@index([companyId])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename    String
  mime        String
  size        Int
  storagePath String
  createdAt   DateTime @default(now())
}

model TaskTag {
  id          String              @id @default(cuid())
  name        String              @unique
  color       String              @default("#3b82f6")
  assignments TaskTagAssignment[]
}

model TaskTagAssignment {
  taskId String
  tagId  String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TgTaskChat {
  chatId  BigInt   @id
  name    String
  addedAt DateTime @default(now())
}

model TgUserBinding {
  userId     String  @id
  tgUserId   BigInt  @unique
  tgUsername String?
}

model TaskSetting {
  key   String @id
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model ScheduledSend {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  mailbox   Mailbox    @relation(fields: [mailboxId], references: [id])
  mailboxId String
  payload   Json
  sendAt    DateTime
  status    SendStatus @default(pending)
  jobId     String?
  createdAt DateTime   @default(now())
}
